{
	"name": "Coding with AI Agents Workshop",
	"image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
	"features": {
		"ghcr.io/astral-sh/uv:1": {},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"anthropic.claude-code",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter",
				"charliermarsh.ruff",
				"marp-team.marp-vscode"
			],
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
				"python.terminal.activateEnvInCurrentTerminal": true,
				"[python]": {
					"editor.defaultFormatter": "charliermarsh.ruff",
					"editor.formatOnSave": true
				}
			}
		}
	},
	"remoteEnv": {
		"LITELLM_API_KEY": "${localEnv:LITELLM_API_KEY}",
		"LITELLM_API_BASE": "${localEnv:LITELLM_API_BASE}",
		"ANTHROPIC_API_KEY": "${localEnv:LITELLM_API_KEY}",
		"ANTHROPIC_BASE_URL": "${localEnv:LITELLM_API_BASE}"
	},
	"postCreateCommand": "bash .devcontainer/postCreate.sh",
	"forwardPorts": [8888],
	"portsAttributes": {
		"8888": {
			"label": "JupyterLab",
			"onAutoForward": "notify"
		}
	}
}
