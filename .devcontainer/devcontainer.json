{
  "name": "Coding with AI Agents Workshop",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "marp-team.marp-vscode",
        "GitHub.copilot-chat",
        "anthropic.claude-code",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff"
      ],
      "settings": {
        "chat.plugins.enabled": false,
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvInCurrentTerminal": true,
        // Keep the classic Python extension's interpreter discovery, which honors
        // python.defaultInterpreterPath above. Without this, the bundled Python
        // Environments extension (ms-python.vscode-python-envs) runs its own
        // discovery, ignores that setting, and prompts "No Python found".
        "python.useEnvironmentsExtension": false,
        "oaicopilot.baseUrl": "${localEnv:LITELLM_BASE_URL}/v1",
        "oaicopilot.models": [
          {
              "id": "claude-sonnet-4-6",
              "displayName": "Claude Sonnet 4.6 (UW SSEC)",
              "owned_by": "uw-ssec",
              "isUserSelectable": true,
              "isDefault": true
          },
          {
              "id": "claude-haiku-4-5-20251001",
              "displayName": "Claude Haiku 4.5 (UW SSEC)",
              "owned_by": "uw-ssec",
              "isUserSelectable": true
          }
      ],
        "workbench.startupEditor": "readme",
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/.git/subtree-cache/**": true,
          "**/node_modules/**": true,
          "**/.venv/**": true,
          // Symlinks into the home-dir agent plugin/skill trees (see
          // .devcontainer/link-agent-resources.sh). Excluded so the watcher
          // doesn't follow them out into ~/.claude and ~/.copilot.
          "**/agent-resources/**": true
        }
      }
    }
  },
  "secrets": {
    "LITELLM_BASE_URL": {
      "description": "Base URL for the LLMoxie / LiteLLM gateway"
    },
    "LITELLM_API_KEY": {
      "description": "API key for the LLMoxie / LiteLLM gateway"
    }
  },
  "mounts": [
    "source=${localWorkspaceFolderBasename}-venv,target=${containerWorkspaceFolder}/.venv,type=volume"
  ],
  "remoteEnv": {
    // OAI_API_KEY is placed in remoteEnv because the LLMoxie Copilot extension runtime reads
    // that OpenAI-compatible environment variable at activation time. Setting it only around
    // lifecycle shell commands would not propagate to the VS Code extension host.
    "OAI_API_KEY": "${localEnv:LITELLM_API_KEY}",
    // Point the GitHub Copilot CLI (BYOK) at the same LLMoxie gateway used by the
    // oaicopilot extension so the CLI exposes the same models. Users can switch
    // among the available models in-session via the /model slash command
    // (e.g. /model claude-sonnet-4-6, /model claude-haiku-4-5-20251001).
    "COPILOT_PROVIDER_BASE_URL": "${localEnv:LITELLM_BASE_URL}/v1",
    "COPILOT_PROVIDER_API_KEY": "${localEnv:LITELLM_API_KEY}",
    "COPILOT_MODEL": "claude-sonnet-4-6"
  },
  "onCreateCommand": "bash .devcontainer/on-create.sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "postAttachCommand": "bash .devcontainer/install-vsix.sh",
  "remoteUser": "vscode"
}
